# ─────────────────────────────────────────────────────────────
# LinkForge — environment variables
# Copy to `.env` (root) for docker-compose, and the app-level
# .env files are derived from these values.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---
POSTGRES_USER=linkforge
POSTGRES_PASSWORD=linkforge
POSTGRES_DB=linkforge
# Consumed by Prisma / NestJS. When running the API outside Docker,
# swap `postgres` for `localhost`.
DATABASE_URL=postgresql://linkforge:linkforge@postgres:5432/linkforge?schema=public

# --- Cache / rate-limit store (Redis) ---
REDIS_URL=redis://redis:6379

# --- API ---
API_PORT=4000
NODE_ENV=development

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900          # 15 minutes (seconds)
JWT_REFRESH_TTL=604800      # 7 days (seconds)

# Public base URL used to build short links (e.g. http://localhost:4000/abc123)
SHORT_LINK_BASE_URL=http://localhost:4000

# --- Web (Next.js) ---
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000
